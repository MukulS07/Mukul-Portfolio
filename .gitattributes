# Set default behavior to automatic line ending normalization
* text=auto

# Enforce LF (Unix-style) line endings for code, styling, and configuration files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.config.js text eol=lf
*.toml text eol=lf
.env* text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
